PORT=4000
# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aura-shop?appName=Cluster0
# Or local
# MONGODB_URI=mongodb://localhost:27017/aura-shop
JWT_SECRET=your-super-secret-jwt-key-change-this
ANTHROPIC_API_KEY=sk-ant-...
FRONTEND_URL=http://localhost:3000
# Fashn.ai virtual try-on — get your key at https://fashn.ai
FASHN_API_KEY=

# ── Shopify App ───────────────────────────────────────────────────────────────
# Create your app at https://partners.shopify.com → Apps → Create app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Scopes needed for product search
SHOPIFY_SCOPES=read_products
# Full public URL of this backend (used to build the OAuth redirect URI)
SHOPIFY_APP_URL=https://your-api-domain.com
# Where to redirect merchants after successful install (optional)
# SHOPIFY_INSTALL_SUCCESS_URL=https://your-api-domain.com/install-success
